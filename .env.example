# === Required ===
# Your Ethereum wallet private key (used for Polymarket CLOB auth & signing)
POLYMARKET_PRIVATE_KEY=

# === Polymarket Deposit Wallet (new system) ===
# If your funds are in a Polymarket Deposit Wallet as PUSD (not old CTF exchange):
#   1. Set FUNDER_ADDRESS to your Deposit Wallet proxy address
#   2. SIGNATURE_TYPE will auto-default to 1 (Poly Proxy)
#   3. Balance detection checks PUSD in the Deposit Wallet
# Example:
#   FUNDER_ADDRESS=0x5fFf5d20c6F5D01caD431be4d28321065bd29b0A

FUNDER_ADDRESS=

# Signature type: 0=EOA (default), 1=Poly Proxy (Deposit Wallet), 2=Gnosis Safe
# Auto-set to 1 when FUNDER_ADDRESS is configured
SIGNATURE_TYPE=

# === Optional ===
# Polygon RPC URL - set one of these for faster balance fetching:
#   Free:   https://polygon.llamarpc.com
#   Free:   https://rpc.ankr.com/polygon  
#   Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   Infura:  https://polygon-mainnet.infura.io/v3/YOUR_API_KEY
# If unset, falls back to public RPCs (may be slow/unreliable)
POLYGON_RPC_URL=

# Port for the dashboard (Railway sets this automatically)
PORT=3000
